#!/bin/bash
###############################################################################
# bootstrap.sh.tmpl — Cloud-init bootstrap script for the Technomancer Stack
# Rendered by Terraform templatefile() — uses ${variable} syntax
#
# Executed as root on first boot. Idempotent where possible.
###############################################################################

set -euo pipefail
export DEBIAN_FRONTEND=noninteractive

LOGFILE="/var/log/technomancer-bootstrap.log"
echo "=== Technomancer Stack Bootstrap: $(date) ===" | tee -a $LOGFILE

####################
# SYSTEM UPDATES
####################
echo "[1/8] Updating system packages..." | tee -a $LOGFILE
apt-get update -qq
apt-get upgrade -y -qq
apt-get install -y -qq \
  curl \
  wget \
  git \
  htop \
  ufw \
  fail2ban \
  unattended-upgrades \
  apt-transport-https \
  ca-certificates \
  gnupg \
  lsb-release \
  jq

####################
# TIMEZONE
####################
echo "[2/8] Setting timezone to ${timezone}..." | tee -a $LOGFILE
timedatectl set-timezone "${timezone}"

####################
# DOCKER
####################
echo "[3/8] Installing Docker..." | tee -a $LOGFILE

# Add Docker's official GPG key
install -m 0755 -d /etc/apt/keyrings
curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
chmod a+r /etc/apt/keyrings/docker.gpg

# Add Docker repository
echo \
  "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu \
  $(lsb_release -cs) stable" | tee /etc/apt/sources.list.d/docker.list > /dev/null

apt-get update -qq
apt-get install -y -qq docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin

# Enable and start Docker
systemctl enable docker
systemctl start docker

echo "Docker installed: $(docker --version)" | tee -a $LOGFILE

####################
# FIREWALL (UFW)
####################
echo "[4/8] Configuring firewall..." | tee -a $LOGFILE

ufw --force reset
ufw default deny incoming
ufw default allow outgoing
ufw allow 22/tcp comment 'SSH'
ufw allow 80/tcp comment 'HTTP (Traefik)'
ufw allow 443/tcp comment 'HTTPS (Traefik)'
ufw --force enable

echo "UFW status:" | tee -a $LOGFILE
ufw status | tee -a $LOGFILE

####################
# FAIL2BAN
####################
echo "[5/8] Configuring fail2ban..." | tee -a $LOGFILE

cat > /etc/fail2ban/jail.local << 'EOF'
[DEFAULT]
bantime  = 3600
findtime = 600
maxretry = 5
destemail = root@localhost
backend = systemd

[sshd]
enabled = true
port = ssh
filter = sshd
logpath = /var/log/auth.log
maxretry = 3
bantime = 86400
EOF

systemctl enable fail2ban
systemctl restart fail2ban

####################
# UNATTENDED UPGRADES
####################
echo "[6/8] Enabling automatic security updates..." | tee -a $LOGFILE

cat > /etc/apt/apt.conf.d/50unattended-upgrades << 'EOF'
Unattended-Upgrade::Allowed-Origins {
    "$${distro_id}:$${distro_codename}";
    "$${distro_id}:$${distro_codename}-security";
    "$${distro_id}ESMApps:$${distro_codename}-apps-security";
    "$${distro_id}ESM:$${distro_codename}-infra-security";
};
Unattended-Upgrade::AutoFixInterruptedDpkg "true";
Unattended-Upgrade::MinimalSteps "true";
Unattended-Upgrade::Remove-Unused-Dependencies "true";
Unattended-Upgrade::Automatic-Reboot "false";
EOF

cat > /etc/apt/apt.conf.d/20auto-upgrades << 'EOF'
APT::Periodic::Update-Package-Lists "1";
APT::Periodic::Download-Upgradeable-Packages "1";
APT::Periodic::AutocleanInterval "7";
APT::Periodic::Unattended-Upgrade "1";
EOF

####################
# STACK DEPLOYMENT
####################
echo "[7/8] Deploying Technomancer Stack..." | tee -a $LOGFILE

DEPLOY_DIR="/opt/technomancer"
mkdir -p $DEPLOY_DIR

# If a git repo is provided, clone it; otherwise create the scaffold manually
if [ -n "${git_repo}" ]; then
  echo "Cloning stack from ${git_repo}..." | tee -a $LOGFILE
  git clone "${git_repo}" $DEPLOY_DIR
else
  echo "No git repo provided. Creating directory scaffold..." | tee -a $LOGFILE
  mkdir -p $DEPLOY_DIR/data/{traefik,n8n,postgres,minio,matomo,matomo-db,vaultwarden,ollama,uptime-kuma,backups/postgres}
  mkdir -p $DEPLOY_DIR/config/{traefik,postgres}
fi

# Create Traefik ACME file with correct permissions (CRITICAL)
touch $DEPLOY_DIR/data/traefik/acme.json
chmod 600 $DEPLOY_DIR/data/traefik/acme.json

# Write .env file from Terraform variables
cat > $DEPLOY_DIR/docker/.env << EOF
BASE_DOMAIN=${domain}
LETSENCRYPT_EMAIL=${email}
TIMEZONE=${timezone}
POSTGRES_USER=technomancer
POSTGRES_PASSWORD=${postgres_password}
N8N_ENCRYPTION_KEY=${n8n_key}
# Fill in remaining variables before starting stack
# See: docker/.env.example for all required variables
EOF

chmod 600 $DEPLOY_DIR/docker/.env
echo "Environment file written to $DEPLOY_DIR/docker/.env" | tee -a $LOGFILE

####################
# COMPLETION
####################
echo "[8/8] Bootstrap complete!" | tee -a $LOGFILE
echo "" | tee -a $LOGFILE
echo "==================================================" | tee -a $LOGFILE
echo "  Technomancer Stack Bootstrap Complete"          | tee -a $LOGFILE
echo "==================================================" | tee -a $LOGFILE
echo "  Server IP:     $(curl -s ifconfig.me)"          | tee -a $LOGFILE
echo "  Domain:        ${domain}"                       | tee -a $LOGFILE
echo "  Deploy dir:    $DEPLOY_DIR"                     | tee -a $LOGFILE
echo ""                                                  | tee -a $LOGFILE
echo "  NEXT STEPS:"                                    | tee -a $LOGFILE
echo "  1. Create DNS wildcard A record: * → $(curl -s ifconfig.me)"   | tee -a $LOGFILE
echo "  2. Complete .env file: $DEPLOY_DIR/docker/.env" | tee -a $LOGFILE
echo "  3. Run: cd $DEPLOY_DIR/docker && docker compose up -d"          | tee -a $LOGFILE
echo "  4. Check: docker compose logs -f"               | tee -a $LOGFILE
echo "==================================================" | tee -a $LOGFILE
