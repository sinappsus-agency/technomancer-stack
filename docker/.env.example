# Environment Variables Reference

# Copy this file to .env and populate all values before running docker compose up

# ============================================================
# DOMAIN CONFIGURATION
# ============================================================
# Your primary domain (e.g., youragency.com)
DOMAIN=yourdomain.com

# Admin email for Let's Encrypt SSL certificate registration
ACME_EMAIL=admin@yourdomain.com

# ============================================================
# TRAEFIK
# ============================================================
# Strong password for Traefik dashboard basic auth
# Generate with: echo $(htpasswd -nb admin yourpassword) | sed -e s/\\$/\\$\\$/g
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$10$$generated_hash_here

# ============================================================
# n8n
# ============================================================
# 32-character random string for encrypting stored credentials
# Generate with: openssl rand -hex 16
N8N_ENCRYPTION_KEY=replace_with_32_char_random_string

# n8n admin credentials (first user created)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin@yourdomain.com
N8N_BASIC_AUTH_PASSWORD=replace_with_strong_password

# ============================================================
# DATABASE (shared PostgreSQL for n8n + ERPNext)
# ============================================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=technomancer
DB_USER=technomancer_user
DB_PASSWORD=replace_with_strong_db_password

# ============================================================
# MINIO
# ============================================================
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=replace_with_strong_password

# ============================================================
# NOTIFUSE
# ============================================================
NOTIFUSE_SECRET_KEY=replace_with_random_secret_key
NOTIFUSE_DB_PASSWORD=replace_with_strong_password

# ============================================================
# SMTP RELAY (for email sending via Notifuse)
# Use SendGrid, Postmark, or your mail server
# ============================================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key
SMTP_FROM_NAME=Your Brand Name
SMTP_FROM_EMAIL=hello@yourdomain.com

# ============================================================
# MATOMO ANALYTICS
# ============================================================
MATOMO_DB_ROOT_PASSWORD=replace_with_strong_password
MATOMO_DB_USER=matomo
MATOMO_DB_PASSWORD=replace_with_strong_password

# ============================================================
# VAULTWARDEN
# ============================================================
# Admin token for the /admin panel
# Generate with: openssl rand -base64 48
VAULTWARDEN_ADMIN_TOKEN=replace_with_admin_token

# ============================================================
# TELEGRAM BOT (for server control + alerts)
# ============================================================
TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
TELEGRAM_ADMIN_CHAT_ID=replace_with_your_telegram_user_id

# ============================================================
# BACKUPS
# ============================================================
# Remote backup destination (S3-compatible, e.g., Backblaze B2)
BACKUP_S3_ENDPOINT=s3.us-west-004.backblazeb2.com
BACKUP_S3_BUCKET=technomancer-backups
BACKUP_S3_ACCESS_KEY=replace_with_backup_access_key
BACKUP_S3_SECRET_KEY=replace_with_backup_secret_key

# ============================================================
# WORDPRESS + WOOCOMMERCE
# ============================================================
MARIADB_ROOT_PASSWORD=replace_with_strong_root_password
WORDPRESS_DB_USER=wordpress_user
WORDPRESS_DB_PASSWORD=replace_with_strong_password

# ============================================================
# CALL CENTER (optional — only needed if using the call center module)
# ============================================================
TELNYX_API_KEY=your_telnyx_api_key
TELNYX_APP_ID=your_telnyx_application_profile_id
DRACHTIO_SECRET=replace_with_strong_drachtio_secret
OPERATOR_TELEGRAM_ID=your_telegram_user_id
