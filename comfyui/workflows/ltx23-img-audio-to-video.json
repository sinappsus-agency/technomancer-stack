  "_meta": {
    "name": "LTX 2.3 Image+Audio to Video",
    "description": "LTX-Video 2.3 22B fp8 — generates video from an input image and audio file. Two-pass pipeline: first pass generates at half-res, second pass upscales with spatial upscaler. Requires: ltx-2.3-22b-dev-fp8, gemma text encoder, distilled LoRA, spatial upscaler, abliterated gemma LoRA.",
    "params": {
      "PARAM_IMAGE": { "node": "269", "key": "image", "type": "file", "description": "Input image filename (upload first with upload_file)" },
      "PARAM_AUDIO": { "node": "276", "key": "audio", "type": "file", "description": "Input audio filename (upload first with upload_file)" },
      "PARAM_POSITIVE_PROMPT": { "node": "319", "key": "value", "type": "string", "description": "Video description prompt — describe motion, camera, and scene" },
      "PARAM_NEGATIVE_PROMPT": { "node": "314", "key": "text", "type": "string", "description": "Negative prompt — elements to exclude from the video" },
      "PARAM_SEED": { "node": "286", "key": "noise_seed", "type": "int", "description": "Random seed for primary sampler (-1 for random)" },
      "PARAM_WIDTH": { "node": "330", "key": "value", "type": "int", "description": "Output width in pixels (default 721)" },
      "PARAM_HEIGHT": { "node": "324", "key": "value", "type": "int", "description": "Output height in pixels (default 1280)" },
      "PARAM_DURATION": { "node": "331", "key": "value", "type": "float", "description": "Video duration in seconds (default 9)" },
      "PARAM_FPS": { "node": "323", "key": "value", "type": "int", "description": "Frames per second (default 24)" }
    }
  },
