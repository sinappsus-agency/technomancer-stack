{
  "_meta": {
    "name": "SDXL Text-to-Image",
    "description": "Basic SDXL text-to-image pipeline. Supports any SDXL-compatible checkpoint.",
    "params": {
      "PARAM_POSITIVE_PROMPT": { "node": "6", "key": "text", "type": "string", "description": "Positive prompt describing the desired image" },
      "PARAM_NEGATIVE_PROMPT": { "node": "7", "key": "text", "type": "string", "description": "Negative prompt — elements to exclude" },
      "PARAM_MODEL": { "node": "4", "key": "ckpt_name", "type": "combo", "description": "Checkpoint filename from models/checkpoints/" },
      "PARAM_SEED": { "node": "8", "key": "seed", "type": "int", "description": "Random seed (-1 for random)" },
      "PARAM_STEPS": { "node": "8", "key": "steps", "type": "int", "description": "Denoising steps (20-40 for SDXL)" },
      "PARAM_CFG": { "node": "8", "key": "cfg", "type": "float", "description": "Classifier-free guidance (6-8 for SDXL)" },
      "PARAM_WIDTH": { "node": "5", "key": "width", "type": "int", "description": "Image width in pixels (multiples of 64)" },
      "PARAM_HEIGHT": { "node": "5", "key": "height", "type": "int", "description": "Image height in pixels (multiples of 64)" }
    }
  },
  "4": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "PARAM_MODEL" }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "inputs": { "width": "PARAM_WIDTH", "height": "PARAM_HEIGHT", "batch_size": 1 }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "PARAM_POSITIVE_PROMPT", "clip": ["4", 1] }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "PARAM_NEGATIVE_PROMPT", "clip": ["4", 1] }
  },
  "8": {
    "class_type": "KSampler",
    "inputs": {
      "seed": "PARAM_SEED",
      "steps": "PARAM_STEPS",
      "cfg": "PARAM_CFG",
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0,
      "model": ["4", 0],
      "positive": ["6", 0],
      "negative": ["7", 0],
      "latent_image": ["5", 0]
    }
  },
  "9": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["8", 0], "vae": ["4", 2] }
  },
  "10": {
    "class_type": "SaveImage",
    "inputs": { "filename_prefix": "mcp", "images": ["9", 0] }
  }
}
